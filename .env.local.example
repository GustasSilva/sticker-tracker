# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase
# (Project Settings -> API). Na Vercel, essas variáveis já devem ter sido
# preenchidas automaticamente pela integração Supabase <-> Vercel.

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
